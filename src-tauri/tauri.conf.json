{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Abencat Browser",
  "version": "0.1.0",
  "identifier": "com.abencat.browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "阿笨猫指纹浏览器 · Abencat Browser",
        "width": 1360,
        "height": 820,
        "minWidth": 1060,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
